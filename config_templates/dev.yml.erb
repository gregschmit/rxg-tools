<%
fqdn = "dev.schmit.net"
wan_cidr = "96.74.246.203/29"
wan_gateway = "96.74.246.206"
%>

<%= ConfigTemplate.include_template(file: "01_initial.yml.erb", context: binding) %>

- admins:
  - login: testadmin
    _delete: true

- ssl_key_chains:
  - name: <%= fqdn %>
    certificate_signing_request:
      name: <%= fqdn %> CSR
      sign_mode: certbot
      common_name: <%= fqdn %>
      extended_key_usage: server
      country: US
      state: Illinois
      locale: Oswego
      email_address: gns@rgnets.com

- subnets_filters:
  - name: Block Subnets
    _delete: true

- net_app_filters:
  - name: Webserver DDoS Abusers Block All
    _delete: true
- ip_groups:
  - name: Webserver DDoS Abusers
    _delete: true
- policies:
  - name: Webserver DDoS Abusers
    _delete: true
- log_hits_triggers:
  - name: Webserver DDoS Prevention
    _delete: true
